<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- Required for the LibraryImport source-gen path used by
         Audio/VstBridgeNative.cs (P/Invoke into zeus-vst-bridge).
         Unsafe usage is bounded to that file's pointer marshaling. -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <PackageReference Include="LiteDB" Version="5.0.21" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Zeus.Plugins.Contracts\Zeus.Plugins.Contracts.csproj" />
    <!-- Build the no-op managed stub but DON'T reference its types — its
         compiled DLL is embedded below and written into each scanned-VST
         plugin dir at runtime. ReferenceOutputAssembly=false keeps it out
         of the host's reference set; the dependency just enforces build
         order so the embedded DLL exists when this project compiles. -->
    <ProjectReference Include="..\Zeus.Plugins.VstHostStub\Zeus.Plugins.VstHostStub.csproj"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

  <!-- Embed the freshly-built stub DLL as a manifest resource so
       VstDirectoryScanService can write it next to a generated plugin.json
       without hunting the filesystem. Path tracks the stub's build output;
       the ProjectReference above guarantees it's produced first. -->
  <ItemGroup>
    <EmbeddedResource Include="..\Zeus.Plugins.VstHostStub\bin\$(Configuration)\net10.0\Zeus.Plugins.VstHostStub.dll">
      <LogicalName>Zeus.Plugins.VstHostStub.dll</LogicalName>
      <Visible>false</Visible>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Zeus.Plugins.Host.Tests" />
  </ItemGroup>

  <!-- Ship the native VST3 host bridge (zeus-vst-bridge) in
       runtimes/<rid>/native, matching the wdsp / miniaudio layout.
       VstBridgeNativeLoader probes that RID-specific directory before
       falling back to the OS load path. Release CI stages a freshly-built
       Windows bridge before publish so installers cannot drift behind the
       native source. When a binary for the current RID is absent the audio
       chain simply never loads a VST — VstHostAudioPlugin throws at init
       and the bridge stays idle. -->
  <ItemGroup>
    <None Include="runtimes/**/*.dll" Pack="true" PackagePath="runtimes/">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>runtimes/%(RecursiveDir)%(Filename)%(Extension)</Link>
    </None>
    <None Include="runtimes/**/*.so*" Pack="true" PackagePath="runtimes/">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>runtimes/%(RecursiveDir)%(Filename)%(Extension)</Link>
    </None>
    <None Include="runtimes/**/*.dylib" Pack="true" PackagePath="runtimes/">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>runtimes/%(RecursiveDir)%(Filename)%(Extension)</Link>
    </None>
  </ItemGroup>

</Project>
