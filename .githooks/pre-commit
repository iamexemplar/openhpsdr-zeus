#!/bin/sh
set -eu

author_ident="$(git var GIT_AUTHOR_IDENT 2>/dev/null || true)"
committer_ident="$(git var GIT_COMMITTER_IDENT 2>/dev/null || true)"

case "$author_ident
$committer_ident" in
  *"Ramon Martinez"*|*"rampa@encomix.org"*)
    echo "Refusing commit with old Ramon/rampa identity." >&2
    echo "Use: Christian Suarez (N9WAR) <christiantsuarez@gmail.com>" >&2
    exit 1
    ;;
esac

case "$author_ident" in
  *"Christian Suarez (N9WAR)"*"<christiantsuarez@gmail.com>"*|*"iamexemplar"*)
    exit 0
    ;;
  *)
    echo "Refusing commit with unexpected author identity:" >&2
    echo "  $author_ident" >&2
    echo "Expected Christian Suarez (N9WAR) <christiantsuarez@gmail.com> or iamexemplar." >&2
    exit 1
    ;;
esac
